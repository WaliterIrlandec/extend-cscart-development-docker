while [ -n "$1" ]
do
case "$1" in
--container_prefix) CONTAINER_PREFIX="$2"
shift ;;
--domain_list) DOMAIN_LIST="$2"
shift ;;
*) echo "$1 is not an option";;
esac
shift
done

NGINX_HOST="${CONTAINER_PREFIX}-nginx"

echo "re-generating ssl cert"

DOMAIN_NAMES=$(echo "$DOMAIN_LIST" | tr ',' ' ')

mkdir -p ./app/ssl/mkcert

# install mkcert binary if not present
docker exec ${NGINX_HOST} /bin/sh -c "
if [ ! -f /usr/local/bin/mkcert ]; then
    wget -q https://github.com/FiloSottile/mkcert/releases/latest/download/mkcert-v1.4.4-linux-amd64 -O /usr/local/bin/mkcert
    chmod +x /usr/local/bin/mkcert
fi
"

# generate CA (stored in /app/ssl/mkcert — persists across container restarts)
docker exec ${NGINX_HOST} /bin/sh -c "CAROOT=/app/ssl/mkcert mkcert -install"

# generate cert for all domains
docker exec ${NGINX_HOST} /bin/sh -c "CAROOT=/app/ssl/mkcert mkcert -key-file /app/ssl/ssl.key -cert-file /app/ssl/ssl.crt ${DOMAIN_NAMES} localhost 127.0.0.1"

echo ""
echo "SSL cert generated."
echo "To trust it in browsers run: make push_ssl_cert_to_browsers"
