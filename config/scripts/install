#!/bin/bash
set -e

echo "Installing..."

mkdir -p ./app/www
mkdir -p ./config/nginx
cp ./config/files/app.conf.example config/nginx/app.conf

cp config/files/.env.example ./.env;

# Project name (CONTAINER_PREFIX)
read -p "Project name [test]: " input_prefix
input_prefix=${input_prefix:-test}
sed -i "s/^CONTAINER_PREFIX=.*/CONTAINER_PREFIX=${input_prefix}/" .env

# Domain list
read -p "Domain names [demo.cscart.local,demo2.cscart.local]: " input_domains
input_domains=${input_domains:-demo.cscart.local,demo2.cscart.local}
sed -i "s/^DOMAIN_LIST=.*/DOMAIN_LIST=${input_domains}/" .env

echo "Config saved: CONTAINER_PREFIX=${input_prefix}, DOMAIN_LIST=${input_domains}"

# Additional settings
read -p "Configure additional settings? (y/N): " edit_answer
if [[ "$edit_answer" == "y" || "$edit_answer" == "Y" ]]
then
  vim .env;
fi

source .env;

echo "Install phpMyAdmin? (y/N):"
read pma_answer
if [[ "$pma_answer" == "y" || "$pma_answer" == "Y" ]]
then
  sed -i '/^# PHPMYADMIN=/d' .env
  sed -i '/^DOMAIN_LIST=/a PHPMYADMIN=Y' .env
  echo "phpMyAdmin enabled";
else
  echo "phpMyAdmin skipped";
fi

./config/scripts/docker-host-remove --domain_list ${DOMAIN_LIST} --container_prefix ${CONTAINER_PREFIX}
docker-compose down 2>/dev/null || true

make run;

echo "Waiting for MySQL to be ready..."
until mysql -u root -p${MYSQL_ROOT_PASSWORD:-root} -h ${CONTAINER_PREFIX}-mysql -e "SELECT 1" 2>/dev/null; do
  sleep 2
done
echo "MySQL is ready"

make init; # to create ssl
make stop;

echo "Activate SSL"
# uncomment ssl nginx
sed -i "s/# listen 443 ssl default_server;/listen 443 ssl default_server;/g;" ./config/nginx/app.conf
sed -i "s/# ssl_certificate     \/app\/ssl\/ssl.crt;/ssl_certificate     \/app\/ssl\/ssl.crt;/g;" ./config/nginx/app.conf
sed -i "s/# ssl_certificate_key \/app\/ssl\/ssl.key;/ssl_certificate_key \/app\/ssl\/ssl.key;/g;" ./config/nginx/app.conf

echo "Docker run"
make run;

echo "Fin!";
