#!/bin/bash
# widev

source .env

MYSQL_REMOTE_HOST="${CONTAINER_PREFIX}-mysql"
MYSQL_USER="${MYSQL_USER:-root}"
export MYSQL_PWD=$MYSQL_ROOT_PASSWORD
MYSQL="$(which mysql)"
SCRIPT_DIR="$(dirname "${BASH_SOURCE[0]}")"
folder="$SCRIPT_DIR/../../bck/from_live"

# [LOG]
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
CYAN='\033[1;36m'
RESET='\033[0m'

log() {
  local COLOR="$1"
  local MESSAGE="$2"
  echo -e "${COLOR}${MESSAGE}${RESET}"
}
# [/LOG]

# [COMMAND-LINE OPTIONS]
DOWNLOAD=false
UNZIP=false
RESTORE=false
FORCE=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --download)
      DOWNLOAD=true
      shift
      ;;
    --unzip)
      UNZIP=true
      shift
      ;;
    --restore)
      RESTORE=true
      shift
      ;;
    --force)
      FORCE=true
      shift
      ;;
    -*)  # Short options, possibly combined
      FLAGS="${1:1}"  # Remove leading dash
      for (( i=0; i<${#FLAGS}; i++ )); do
        case "${FLAGS:$i:1}" in
          d) DOWNLOAD=true ;;
          z) UNZIP=true ;;
          r) RESTORE=true ;;
          f) FORCE=true ;;
          *) log "$RED" "Unknown option: -${FLAGS:$i:1}"; exit 1 ;;
        esac
      done
      shift
      ;;
    *)
      log "$RED" "Unknown argument: $1"
      exit 1
      ;;
  esac
done
# [/COMMAND-LINE OPTIONS]

log "$GREEN" "start"

if [ "$DOWNLOAD" = true ]; then
log "$CYAN" "[DOWNLOAD]"

REMOVE_BCK_TYPE="${REMOVE_BCK_TYPE:-curl}"

if [ "$REMOVE_BCK_TYPE" = "ssh_dump" ]; then
	if [ -z "$REMOVE_BCK_URL" ] || [ -z "$REMOVE_BCK_SSH_DB" ] || [ -z "$REMOVE_BCK_SSH_DB_USER" ] || [ -z "$REMOVE_BCK_SSH_DB_PASS" ]; then
		log "$RED" "REMOVE_BCK_URL, REMOVE_BCK_SSH_DB, REMOVE_BCK_SSH_DB_USER, REMOVE_BCK_SSH_DB_PASS are required for ssh_dump mode. Skip download…"
	else
		mkdir -p "$folder"
		DUMP_DATE=$(date +%Y%m%d_%H%M%S)
		DUMP_FILE="$folder/${REMOVE_BCK_SSH_DB}.${DUMP_DATE}.sql.gz"

		# Escape password for safe passing through SSH
		ESCAPED_PASS=$(printf '%q' "$REMOVE_BCK_SSH_DB_PASS")

		# Resolve table name (expand wildcards via SHOW TABLES LIKE on remote)
		resolve_tables() {
			local pattern="$1"
			if [[ "$pattern" == *"*"* ]]; then
				local like_pattern="${pattern//\*/%}"
				ssh "$REMOVE_BCK_URL" "mysql -u '${REMOVE_BCK_SSH_DB_USER}' -p${ESCAPED_PASS} -N -e \"SHOW TABLES LIKE '${like_pattern}'\" ${REMOVE_BCK_SSH_DB}" 2>/dev/null
			else
				echo "$pattern"
			fi
		}

		# Build --ignore-table options
		IGNORE_OPTS=""
		if [ -n "$REMOVE_BCK_IGNORE_TABLES" ]; then
			IFS=',' read -r -a IGNORE_ARR <<< "$REMOVE_BCK_IGNORE_TABLES"
			for t in "${IGNORE_ARR[@]}"; do
				t=$(echo "$t" | xargs)
				while IFS= read -r resolved; do
					[ -n "$resolved" ] && IGNORE_OPTS="$IGNORE_OPTS --ignore-table=${REMOVE_BCK_SSH_DB}.${resolved}"
				done <<< "$(resolve_tables "$t")"
			done
		fi

		# Also ignore structure-only tables from main dump
		STRUCTURE_OPTS=""
		if [ -n "$REMOVE_BCK_STRUCTURE_ONLY" ]; then
			IFS=',' read -r -a STRUCT_ARR <<< "$REMOVE_BCK_STRUCTURE_ONLY"
			for t in "${STRUCT_ARR[@]}"; do
				t=$(echo "$t" | xargs)
				while IFS= read -r resolved; do
					if [ -n "$resolved" ]; then
						IGNORE_OPTS="$IGNORE_OPTS --ignore-table=${REMOVE_BCK_SSH_DB}.${resolved}"
						STRUCTURE_OPTS="$STRUCTURE_OPTS ${resolved}"
					fi
				done <<< "$(resolve_tables "$t")"
			done
		fi

		# Main dump (data + structure, excluding ignored and structure-only tables)
		log "$BLUE" "Running mysqldump (data) on remote server via SSH..."
		ssh "$REMOVE_BCK_URL" "mysqldump -u '${REMOVE_BCK_SSH_DB_USER}' -p${ESCAPED_PASS} ${REMOVE_BCK_SSH_DB} ${IGNORE_OPTS} | gzip" | pv > "$DUMP_FILE"

		if [ $? -eq 0 ] && [ -s "$DUMP_FILE" ]; then
			log "$GREEN" "Dump saved: $DUMP_FILE ($(du -h "$DUMP_FILE" | cut -f1))"
		else
			log "$RED" "ssh_dump (data) failed"
			rm -f "$DUMP_FILE"
			exit 1
		fi

		# Structure-only dump (if set)
		if [ -n "$STRUCTURE_OPTS" ]; then
			STRUCT_FILE="$folder/${REMOVE_BCK_SSH_DB}.${DUMP_DATE}.structure.sql.gz"
			log "$BLUE" "Running mysqldump (structure only) on remote server via SSH..."
			ssh "$REMOVE_BCK_URL" "mysqldump -u '${REMOVE_BCK_SSH_DB_USER}' -p${ESCAPED_PASS} --no-data ${REMOVE_BCK_SSH_DB} ${STRUCTURE_OPTS} | gzip" | pv > "$STRUCT_FILE"

			if [ $? -eq 0 ] && [ -s "$STRUCT_FILE" ]; then
				log "$GREEN" "Structure dump saved: $STRUCT_FILE ($(du -h "$STRUCT_FILE" | cut -f1))"
			else
				log "$RED" "ssh_dump (structure) failed"
				rm -f "$STRUCT_FILE"
				exit 1
			fi
		fi
	fi
elif [ -z "$REMOVE_BCK_URL" ] || [ -z "$REMOVE_BCK_FILES" ]; then
	log "$RED" "REMOVE_BCK_URL, REMOVE_BCK_FILES are required. Skip download…"
elif [ "$REMOVE_BCK_TYPE" = "curl" ] && { [ -z "$REMOVE_BCK_USER" ] || [ -z "$REMOVE_BCK_PWD" ]; }; then
	log "$RED" "REMOVE_BCK_USER, REMOVE_BCK_PWD are required for curl mode. Skip download…"
else
	# SCP: split host:path from REMOVE_BCK_URL
	if [ "$REMOVE_BCK_TYPE" = "scp" ]; then
		SCP_HOST="${REMOVE_BCK_URL%%:*}"
		SCP_PATH="${REMOVE_BCK_URL#*:}"
	fi

	check_file() {
		local file="$1"
		if [ "$REMOVE_BCK_TYPE" = "scp" ]; then
			ssh "$SCP_HOST" "test -f '${SCP_PATH}${file}'" 2>/dev/null
		else
			curl --silent --head --fail -u "$REMOVE_BCK_USER:$REMOVE_BCK_PWD" "$REMOVE_BCK_URL$file" > /dev/null
		fi
	}

	download_file() {
		local file="$1"
		if [ "$REMOVE_BCK_TYPE" = "scp" ]; then
			scp "$SCP_HOST:${SCP_PATH}${file}" "$folder/"
		else
			curl -u "$REMOVE_BCK_USER:$REMOVE_BCK_PWD" -O "$REMOVE_BCK_URL$file" --output-dir "$folder"
		fi
	}

	# get remote file size in bytes
	get_remote_size() {
		local file="$1"
		if [ "$REMOVE_BCK_TYPE" = "scp" ]; then
			ssh "$SCP_HOST" "stat -c%s '${SCP_PATH}${file}'" 2>/dev/null
		else
			curl --silent --head -u "$REMOVE_BCK_USER:$REMOVE_BCK_PWD" "$REMOVE_BCK_URL$file" 2>/dev/null | grep -i content-length | awk '{print $2}' | tr -d '\r'
		fi
	}

	get_available_date() {
		local filename="$1"
		local current_date=$(date +%Y%m%d)
		local yesterday_date=$(date -d "yesterday" +%Y%m%d)

		# check if exist today's bck
		if check_file "${filename//%DATE%/$current_date}"; then
			echo "$current_date"
		# if no, check yesterday's bck
		elif check_file "${filename//%DATE%/$yesterday_date}"; then
			echo "$yesterday_date"
		else
			echo ""
		fi
	}

	mkdir -p "$folder"

	IFS=',' read -r -a FILE_PATTERNS <<< "$REMOVE_BCK_FILES"

	# Try to get the available date for the first file
	FILENAME="${FILE_PATTERNS[0]}"
	AVAILABLE_DATE=$(get_available_date "$FILENAME")

	if [ -z "$AVAILABLE_DATE" ]; then
		log "$RED" "no remote backup files or error access"
		exit 1
	fi

	for PATTERN in "${FILE_PATTERNS[@]}"; do
		# remove spaces
		CLEANED=$(echo "$PATTERN" | xargs)

		if [ -z "$CLEANED" ]; then
			continue
		fi

		FILENAME="${CLEANED//%DATE%/$AVAILABLE_DATE}"

		# skip download if local file matches remote size (unless --force)
		# also skip if unzipped version already exists (.zst → .sql, .gz → .sql)
		LOCAL_FILE="$folder/$FILENAME"
		if [ "$FORCE" != true ]; then
			UNPACKED_FILE="${LOCAL_FILE%.zst}"
			UNPACKED_FILE="${UNPACKED_FILE%.gz}"
			if [ "$UNPACKED_FILE" != "$LOCAL_FILE" ] && [ -f "$UNPACKED_FILE" ]; then
				# remove leftover archive from interrupted download
				[ -f "$LOCAL_FILE" ] && rm "$LOCAL_FILE"
				log "$YELLOW" "Skip (already unpacked): $UNPACKED_FILE"
				continue
			fi
			if [ -f "$LOCAL_FILE" ]; then
				LOCAL_SIZE=$(stat -c%s "$LOCAL_FILE" 2>/dev/null)
				REMOTE_SIZE=$(get_remote_size "$FILENAME")
				if [ -n "$REMOTE_SIZE" ] && [ "$LOCAL_SIZE" = "$REMOTE_SIZE" ]; then
					log "$YELLOW" "Skip (already downloaded, same size $LOCAL_SIZE): $FILENAME"
					continue
				fi
			fi
		fi

		log "$BLUE" "Download ($REMOVE_BCK_TYPE): $FILENAME"
		download_file "$FILENAME"
	done
fi
log "$CYAN" "[/DOWNLOAD]"
fi

if ! find $folder -type f | read; then
	log "$RED" "backup folder is empty"
	exit 1
fi

if [ "$UNZIP" = true ]; then
log "$CYAN" "[UNZIP]"
UNZIP_FOUND=false

if ls "$folder"/*.gz &>/dev/null; then
	UNZIP_FOUND=true
	for archive in "$folder"/*.gz; do
		if [ -f "$archive" ]; then
			log "$BLUE" "Unzip (gz): $archive..."
			gunzip "$archive"
		fi
	done
fi

if ls "$folder"/*.zst &>/dev/null; then
	UNZIP_FOUND=true
	for archive in "$folder"/*.zst; do
		if [ -f "$archive" ]; then
			log "$BLUE" "Unzip (zst): $archive..."
			zstd -d -f --rm "$archive"
		fi
	done
fi

if [ "$UNZIP_FOUND" = false ]; then
	log "$RED" "No .gz or .zst files"
fi
log "$CYAN" "[/UNZIP]"
fi

if [ "$RESTORE" = true ]; then
log "$CYAN"  "[RESTORE]"
mysqladmin -u $MYSQL_USER -h $MYSQL_REMOTE_HOST status &>/dev/null
if [ ! $? -eq 0 ]; then
	log "$RED" "MySQL server not available"
	exit 1;
fi

if ls "$folder"/*.sql &>/dev/null; then
	# Disable checks and redo log for faster import
	log "$BLUE" "Disabling checks and redo log for faster import..."
	$MYSQL -u $MYSQL_USER -h $MYSQL_REMOTE_HOST -e "SET GLOBAL foreign_key_checks=0; SET GLOBAL unique_checks=0; ALTER INSTANCE DISABLE INNODB REDO_LOG;" 2>/dev/null

	for sql_file in "$folder"/*.sql; do
		if [ -f "$sql_file" ]; then
			log "$BLUE" "Restoring: $sql_file..."
			pv "$sql_file" | $MYSQL -u $MYSQL_USER -h $MYSQL_REMOTE_HOST $MYSQL_DB --init-command="SET foreign_key_checks=0; SET unique_checks=0; SET sql_log_bin=0;"

			# If the restoration is successful
			if [ $? -eq 0 ]; then
				log "$YELLOW" "Restoration successful, deleting $sql_file..."
				rm "$sql_file"
			else
				log "$RED" "Restoration failed for $sql_file, skipping deletion."
				$MYSQL -u $MYSQL_USER -h $MYSQL_REMOTE_HOST -e "ALTER INSTANCE ENABLE INNODB REDO_LOG; SET GLOBAL foreign_key_checks=1; SET GLOBAL unique_checks=1;" 2>/dev/null
				exit 1
			fi
		fi
	done

	# Re-enable redo log and checks
	log "$BLUE" "Re-enabling redo log and checks..."
	$MYSQL -u $MYSQL_USER -h $MYSQL_REMOTE_HOST -e "ALTER INSTANCE ENABLE INNODB REDO_LOG; SET GLOBAL foreign_key_checks=1; SET GLOBAL unique_checks=1;" 2>/dev/null
else
	log "$RED" "No .sql files"
fi
log "$CYAN" "[/RESTORE]"
fi

log "$GREEN" "fin"
exit 0